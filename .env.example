OPENCLAUDIO_PORT=18890
OPENCLAUDIO_BIND_ADDRESS=127.0.0.1
# Optional: defaults resolve from the current user's home directory.
# OPENCLAUDIO_WORKSPACE_ROOT=/path/to/.openclaw/workspace
# OPENCLAUDIO_OPENCLAW_ROOT=/path/to/.openclaw
OPENCLAUDIO_GATEWAY_UNIT=openclaw-gateway.service
OPENCLAUDIO_LOG_DIR=/tmp/openclaw
OPENCLAUDIO_SESSION_SECRET=change-me-to-a-random-secret
OPENCLAUDIO_ADMIN_USER=admin
OPENCLAUDIO_ADMIN_PASSWORD_HASH=$2a$10$replace.with.a.real.bcrypt.hash
